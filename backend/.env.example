# LLM Configuration - Groq API (Free, Fast)
# Daftar di https://console.groq.com untuk mendapatkan API key
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL_NAME=llama-3.3-70b-versatile
LLM_API_KEY=gsk_your_groq_api_key_here

# Rate Limiting
# Delay (seconds) between API calls in clause-by-clause mode.
# Default 2.5s keeps under 30 req/min on Groq free tier.
# Set to 0 for local LLMs or paid tiers with no rate limit.
RATE_LIMIT_DELAY_SECONDS=2.5

# ChromaDB Configuration
CHROMA_DB_PATH=data/chroma_db

# Templates Configuration
TEMPLATES_DIR=data/templates

# Embedding Configuration
EMBEDDING_MODEL=nomic-embed-text-v1.5

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Application
APP_NAME=CLMS RAG Pipeline
APP_VERSION=1.0.0
DEBUG=False
